    "#10.Write a Python program to sum all the numeric items in a list?\n",
    "\n",
    "lst = [2,1,'a',2,\"hammad\",3,4.212,4]\n",
    "s = 0\n",
    "for x in range(len(lst)):\n",
    "    if type(lst[x]) == int:\n",
    "        s += lst[x]\n",
    "print(s)\n"
